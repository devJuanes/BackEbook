# Ejemplo de configuración nginx para un subdominio (ej. backebook.tudominio.com)
# Copiar a /etc/nginx/sites-available/backebook y enlazar en sites-enabled.
# Ajustar server_name y ruta del certificado SSL si usas HTTPS.

upstream backebook {
    server 127.0.0.1:9753;
    keepalive 32;
}

server {
    listen 80;
    server_name backebook.tudominio.com;

    location / {
        proxy_pass http://backebook;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

